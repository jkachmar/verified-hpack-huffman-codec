(* Executable chunk buffers (natural `igcmalloc_of_list` return type — see the
   header: the opaque-contents match VC is superlinear at large sizes). The chunks
   are read by `Hpack.Huffman.Lowstar.Dfa.read_cell`, a 16-way `match` over these
   named buffers (a C `switch`); the `dfa_chunk_list` selector used by the proof is
   hand-written in `Hpack.Huffman.Refine.DfaTable`. *)

let dfa_chunk_0
  : b:IB.libuffer U32.t (normalize_term (L.length dfa_chunk_0_data)) (Seq.seq_of_list dfa_chunk_0_list){ IB.recallable b } =
  IB.igcmalloc_of_list HS.root dfa_chunk_0_data

let dfa_chunk_1
  : b:IB.libuffer U32.t (normalize_term (L.length dfa_chunk_1_data)) (Seq.seq_of_list dfa_chunk_1_list){ IB.recallable b } =
  IB.igcmalloc_of_list HS.root dfa_chunk_1_data

